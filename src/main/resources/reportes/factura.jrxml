<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="factura" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>
	<parameter name="LOGO_DILO" class="java.io.InputStream"/>
	<parameter name="NUMERO_FACTURA" class="java.lang.String"/>
	<parameter name="FECHA_EMISION" class="java.lang.String"/>
	<parameter name="CLAVE_ACCESO" class="java.lang.String"/>
	<parameter name="RAZON_SOCIAL" class="java.lang.String"/>
	<parameter name="RUC" class="java.lang.String"/>
	<parameter name="DIRECCION" class="java.lang.String"/>
	<parameter name="CLIENTE_NOMBRE" class="java.lang.String"/>
	<parameter name="CLIENTE_DNI" class="java.lang.String"/>
	<parameter name="SUBTOTAL" class="java.math.BigDecimal"/>
	<parameter name="IVA" class="java.math.BigDecimal"/>
	<parameter name="TOTAL" class="java.math.BigDecimal"/>
	<field name="cantidad" class="java.lang.Integer"/>
	<field name="producto.nombre" class="java.lang.String"/>
	<field name="precioUnitario" class="java.math.BigDecimal"/>
	<field name="subtotalItem" class="java.math.BigDecimal"/>

	<background>
		<band/>
	</background>

	<title>
		<band height="140">
			<image>
				<reportElement x="0" y="0" width="130" height="40"/>
				<imageExpression><![CDATA[$P{LOGO_DILO}]]></imageExpression>
			</image>
			<rectangle radius="5">
				<reportElement x="280" y="0" width="275" height="130" backcolor="#F7F9FC"/>
				<graphicElement>
					<pen lineWidth="0.5" lineColor="#B0B0B0"/>
				</graphicElement>
			</rectangle>
			<staticText>
				<reportElement x="290" y="10" width="100" height="20"/>
				<textElement>
					<font size="14" isBold="true"/>
				</textElement>
				<text><![CDATA[FACTURA]]></text>
			</staticText>
			<textField>
				<reportElement x="390" y="10" width="155" height="20" forecolor="#D92525"/>
				<textElement textAlignment="Right">
					<font size="14" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["No. " + $P{NUMERO_FACTURA}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="290" y="40" width="100" height="15"/>
				<textElement>
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Fecha Emisión:]]></text>
			</staticText>
			<textField>
				<reportElement x="390" y="40" width="155" height="15"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression><![CDATA[$P{FECHA_EMISION}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="290" y="60" width="100" height="15"/>
				<textElement>
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Clave de Acceso:]]></text>
			</staticText>
			<textField>
				<reportElement x="290" y="80" width="255" height="40"/>
				<textElement textAlignment="Center">
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{CLAVE_ACCESO}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="45" width="270" height="25"/>
				<textElement>
					<font size="16" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{RAZON_SOCIAL}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="0" y="70" width="270" height="20"/>
				<textElement>
					<font size="12"/>
				</textElement>
				<textFieldExpression><![CDATA["RUC: " + $P{RUC}]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight">
				<reportElement x="0" y="90" width="270" height="40"/>
				<textFieldExpression><![CDATA["Dirección Matriz: " + $P{DIRECCION}]]></textFieldExpression>
			</textField>
		</band>
	</title>

	<pageHeader>
		<band height="60">
			<rectangle radius="3">
				<reportElement x="0" y="5" width="555" height="45"/>
				<graphicElement>
					<pen lineWidth="0.5" lineColor="#B0B0B0"/>
				</graphicElement>
			</rectangle>
			<staticText>
				<reportElement x="10" y="15" width="100" height="20"/>
				<textElement>
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Razón Social:]]></text>
			</staticText>
			<textField>
				<reportElement x="110" y="15" width="230" height="20"/>
				<textFieldExpression><![CDATA[$P{CLIENTE_NOMBRE}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="350" y="15" width="60" height="20"/>
				<textElement>
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[RUC/DNI:]]></text>
			</staticText>
			<textField>
				<reportElement x="410" y="15" width="135" height="20"/>
				<textFieldExpression><![CDATA[$P{CLIENTE_DNI}]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>

	<columnHeader>
		<band height="25">
			<rectangle>
				<reportElement x="0" y="0" width="555" height="25" backcolor="#2D3E50"/>
				<graphicElement>
					<pen lineWidth="0.0"/>
				</graphicElement>
			</rectangle>
			<staticText>
				<reportElement x="10" y="5" width="60" height="15" forecolor="#FFFFFF"/>
				<textElement>
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Cantidad]]></text>
			</staticText>
			<staticText>
				<reportElement x="80" y="5" width="270" height="15" forecolor="#FFFFFF"/>
				<textElement>
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Descripción del Producto]]></text>
			</staticText>
			<staticText>
				<reportElement x="360" y="5" width="90" height="15" forecolor="#FFFFFF"/>
				<textElement textAlignment="Right">
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Precio Unit.]]></text>
			</staticText>
			<staticText>
				<reportElement x="460" y="5" width="85" height="15" forecolor="#FFFFFF"/>
				<textElement textAlignment="Right">
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Total]]></text>
			</staticText>
		</band>
	</columnHeader>

	<detail>
		<band height="25">
			<line>
				<reportElement x="0" y="24" width="555" height="1" forecolor="#E0E0E0"/>
			</line>
			<textField>
				<reportElement x="10" y="5" width="60" height="15"/>
				<textFieldExpression><![CDATA[$F{cantidad}]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight">
				<reportElement x="80" y="5" width="270" height="15"/>
				<textFieldExpression><![CDATA[$F{producto.nombre}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00">
				<reportElement x="360" y="5" width="90" height="15"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression><![CDATA[$F{precioUnitario}]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00">
				<reportElement x="460" y="5" width="85" height="15"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression><![CDATA[$F{subtotalItem}]]></textFieldExpression>
			</textField>
		</band>
	</detail>

	<summary>
		<band height="100">
			<rectangle radius="5">
				<reportElement x="350" y="10" width="205" height="80"/>
				<graphicElement>
					<pen lineWidth="0.5" lineColor="#B0B0B0"/>
				</graphicElement>
			</rectangle>
			<staticText>
				<reportElement x="360" y="20" width="90" height="15"/>
				<textElement>
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[SUBTOTAL:]]></text>
			</staticText>
			<textField pattern="$ #,##0.00">
				<reportElement x="460" y="20" width="85" height="15"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression><![CDATA[$P{SUBTOTAL}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="360" y="40" width="90" height="15"/>
				<textElement>
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[IVA:]]></text>
			</staticText>
			<textField pattern="$ #,##0.00">
				<reportElement x="460" y="40" width="85" height="15"/>
				<textElement textAlignment="Right"/>
				<textFieldExpression><![CDATA[$P{IVA}]]></textFieldExpression>
			</textField>
			<line>
				<reportElement x="360" y="60" width="185" height="1"/>
			</line>
			<staticText>
				<reportElement x="360" y="65" width="90" height="20"/>
				<textElement>
					<font size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[TOTAL:]]></text>
			</staticText>
			<textField pattern="$ #,##0.00">
				<reportElement x="450" y="65" width="95" height="20"/>
				<textElement textAlignment="Right">
					<font size="12" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{TOTAL}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="0" y="70" width="300" height="20" forecolor="#808080"/>
				<textElement>
					<font size="9" isItalic="true"/>
				</textElement>
				<text><![CDATA[Documento generado por Dilo - Facturación Inteligente]]></text>
			</staticText>
		</band>
	</summary>
</jasperReport>